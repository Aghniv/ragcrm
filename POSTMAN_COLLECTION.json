{
  "info": {
    "name": "AuraCRM API",
    "description": "API collection for AuraCRM - AI Sales Copilot CRM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set('token', jsonData.token);",
                  "    }",
                  "    pm.test(\"Registration successful\", function() {",
                  "        pm.expect(jsonData.token).to.not.be.null;",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}",
                  "pm.test(\"Login successful\", function() {",
                  "    pm.expect(jsonData.token).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/leads",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@startup.io\",\n  \"phone\": \"1234567890\",\n  \"company\": \"Startup Inc\",\n  \"source\": \"LinkedIn\",\n  \"status\": \"NEW\",\n  \"notes\": \"Interested in enterprise plan\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Lead created successfully\", function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leads?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "20"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Leads retrieved successfully\", function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.content).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Lead by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leads/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update Lead",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/leads/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Updated\",\n  \"email\": \"jane.updated@startup.io\",\n  \"phone\": \"9876543210\",\n  \"company\": \"Updated Corp\",\n  \"source\": \"Referral\",\n  \"status\": \"CONTACTED\",\n  \"notes\": \"Called and left voicemail\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Lead updated successfully\", function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Analyze Lead (AI)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/leads/1/analyze",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Lead analyzed successfully\", function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.score).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Leads by Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leads/status/NEW",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Search Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leads?search=Jane",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads"],
              "query": [
                {"key": "search", "value": "Jane"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Bulk Update Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/leads/bulk/status?status=QUALIFIED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads", "bulk", "status"],
              "query": [
                {"key": "status", "value": "QUALIFIED"}
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[1, 2, 3]"
            }
          }
        },
        {
          "name": "Export Leads to CSV",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leads/export",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Lead",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/leads/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Lead deleted successfully\", function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}